# ═══════════════════════════════════════════════════════════════
# Qatar Early Warning System — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────
# SERVER
# ───────────────────────────────────────────────────────────────

# Port the Express server listens on.
# Change this if 3001 is already in use on your machine.
PORT=3001


# ───────────────────────────────────────────────────────────────
# WEB PUSH / VAPID
# ───────────────────────────────────────────────────────────────
# VAPID keys authenticate your server when sending push
# notifications to subscribers' browsers.
#
# Generate a fresh key pair by running:
#   npm run generate-vapid-keys
#
# Copy the output values into the two fields below.
# Keep the private key secret — treat it like a password.

# The public VAPID key (sent to the browser to set up push).
VAPID_PUBLIC_KEY=

# The private VAPID key (used server-side to sign push requests).
VAPID_PRIVATE_KEY=

# Contact email included in push requests so browser vendors can
# reach you if your server causes problems. Use a real address.
# Format must be:  mailto:you@example.com
VAPID_EMAIL=


# ───────────────────────────────────────────────────────────────
# TELEGRAM
# ───────────────────────────────────────────────────────────────
# The EWS backend polls the Telegram Bot API to collect messages
# from monitored channels.
#
# How to get a bot token:
#   1. Open Telegram and search for @BotFather
#   2. Send /newbot and follow the prompts
#   3. Copy the token BotFather gives you (format: 123456:ABC-xyz...)
#
# Important: your bot must be added as an admin to each channel
# you want to monitor, otherwise it will not receive posts.

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram channel usernames or IDs to
# monitor. Use the public username (without @) or the numeric ID.
# Example: channel1,channel2,irannewsfa
TELEGRAM_CHANNELS=


# ───────────────────────────────────────────────────────────────
# FAA NOTAM API
# ───────────────────────────────────────────────────────────────
# The FAA Digital NOTAM API provides Notice to Air Missions data.
# The EWS backend queries it for the OIIX, OIKK, OIGG, and OTBD
# ICAO regions (Tehran, Kerman, Isfahan FIRs, and Doha).
#
# How to get credentials:
#   1. Go to https://api.faa.gov/
#   2. Click "Sign Up" and create a free developer account
#   3. Register a new application to receive your client ID and
#      client secret
#   4. The free tier is sufficient for polling every 5 minutes

# FAA API client ID (from your registered app at api.faa.gov).
FAA_CLIENT_ID=

# FAA API client secret (from your registered app at api.faa.gov).
FAA_CLIENT_SECRET=
